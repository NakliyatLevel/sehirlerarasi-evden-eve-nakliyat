// Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// Site Settings - Tüm site ayarları (domain, şirket adı, iletişim vs.)
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// Users - Admin kullanıcıları
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("admin")
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

// Pages - Dinamik sayfalar (ana sayfa, hakkımızda vs.)
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     Json     // Flexible content blocks
  seoTitle    String?
  seoDesc     String?  @db.Text
  seoKeywords String?  @db.Text
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

// Posts - Blog yazıları
model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?  @db.Text
  content     String   @db.Text
  image       String?
  author      String   @default("Admin")
  published   Boolean  @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?  @db.Text
  seoKeywords String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
}

// Gallery - Galeri görselleri
model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  image       String
  category    String?  // before, after, process
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@index([category])
}

// Reviews - Müşteri yorumları
model Review {
  id        String   @id @default(cuid())
  name      String
  comment   String   @db.Text
  rating    Int      @default(5)
  location  String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved])
  @@index([rating])
}

// FAQ - Sıkça Sorulan Sorular
model FAQ {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  category  String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@index([category])
}

// PricingSetting - Fiyatlandırma ayarları
model PricingSetting {
  id        String   @id @default(cuid())
  type      String   // 'lokal' veya 'international'
  key       String
  value     Json     // Flexible pricing data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, key])
  @@index([type])
}

// Country - Uluslararası ülkeler
model Country {
  id              String   @id @default(cuid())
  code            String   @unique // ISO code (DE, NL, etc.)
  name            String
  nameTr          String   // Türkçe isim
  basePrice       Float    @default(0)
  pricePerKm      Float    @default(0)
  customsFee      Float    @default(0)
  insuranceRate   Float    @default(0)
  active          Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([active])
  @@index([order])
}

// Service - Hizmetler (opsiyonel, sayfa yönetimi için)
model Service {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?  @db.Text
  content         String?  @db.Text // HTML içerik (detay sayfası için)
  image           String?  // Hizmet görseli
  icon            String?  // Lucide icon name
  benefits        String?  @db.Text // Her satır bir avantaj
  metaTitle       String?
  metaDescription String?  @db.Text
  order           Int      @default(0)
  active          Boolean  @default(true)
  showOnHomepage  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([active])
  @@index([showOnHomepage])
  @@index([order])
}

// Solution - Çözümler
model Solution {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?  @db.Text
  content         String?  @db.Text
  image           String?
  icon            String?
  metaTitle       String?
  metaDescription String?  @db.Text
  order           Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([active])
  @@index([order])
}

// Feature - Özellikler (Neden Biz? section)
model Feature {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon        String   // Lucide icon name
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([active])
}

// Statistic - İstatistikler (Sayılar section)
model Statistic {
  id          String   @id @default(cuid())
  title       String
  value       String   // "1000+", "15 Yıl" gibi
  icon        String?  // Lucide icon name (optional)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([active])
}

// Process - Süreç Adımları (Nasıl Çalışır? section)
model Process {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  step        Int      // 1, 2, 3, 4...
  icon        String   // Lucide icon name
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([step])
  @@index([active])
}

// ServiceArea - Hizmet Verdiğimiz Bölgeler
model ServiceArea {
  id              String   @id @default(cuid())
  city            String
  slug            String   @unique
  description     String?  @db.Text
  content         String?  @db.Text // HTML içerik (blog gibi)
  image           String?  // Bölge görseli
  metaTitle       String?
  metaDescription String?  @db.Text
  active          Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([order])
  @@index([active])
}

// Partner - Referanslar / Çalıştığımız Firmalar
model Partner {
  id          String   @id @default(cuid())
  name        String
  logo        String?  // Logo URL
  website     String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([active])
}

// TeamMember - Ekip Üyeleri
model TeamMember {
  id          String   @id @default(cuid())
  name        String
  position    String
  bio         String?  @db.Text
  image       String?  // Profil fotoğrafı URL
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@index([active])
}

// ContactSubmission - İletişim formu kayıtları (opsiyonel - email için)
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Media - Medya kütüphanesi (SEO-friendly resim yönetimi)
model Media {
  id           String   @id @default(cuid())
  filename     String   @unique // istanbul-evden-eve-nakliyat.webp
  originalName String   // Kullanıcının yüklediği orijinal ad
  url          String   // /uploads/istanbul-evden-eve-nakliyat.webp
  alt          String?  @db.Text // SEO alt tag
  size         Int      // Dosya boyutu (bytes)
  mimeType     String   // image/webp, image/jpeg vs.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([filename])
  @@index([createdAt])
}

// Quote - Teklif talepleri
model Quote {
  id               String    @id @default(cuid())
  fullName         String
  phone            String
  email            String
  preferredDate    DateTime?
  fromAddress      String    @db.Text
  fromFloor        Int
  fromElevator     Boolean
  toAddress        String    @db.Text
  toFloor          Int
  toElevator       Boolean
  distance         Float?
  propertyType     String
  rooms            Int
  furnitureCount   Int
  hasFragileItems  Boolean   @default(false)
  hasPiano         Boolean   @default(false)
  hasAntiques      Boolean   @default(false)
  specialItems     String?   @db.Text
  needsPacking     Boolean   @default(false)
  needsDisassembly Boolean   @default(false)
  needsStorage     Boolean   @default(false)
  needsInsurance   Boolean   @default(false)
  additionalNotes  String?   @db.Text
  status           String    @default("pending") // pending, contacted, quoted, completed
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}
